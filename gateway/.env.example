# Supabase (session store)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Gateway API auth (External → Gateway)
GATEWAY_API_KEY=dev-key-change-me

# Planner LLM
ANTHROPIC_API_KEY=sk-ant-...
# OR
# OPENAI_API_KEY=sk-...

# Server
GATEWAY_PORT=3774
GATEWAY_HOSTNAME=0.0.0.0

# -----------------------------------------------------------------------------
# DID identity (optional — required only for talking to auth.type=did_signed peers)
# -----------------------------------------------------------------------------
# The gateway signs outbound A2A requests with this Ed25519 identity when
# the peer's auth config is did_signed. Signing is optional — if you only
# talk to peers configured with `bearer` / `bearer_env` / `none`, leave
# these unset and the gateway runs exactly like it did before DID support.
#
# All three must be set together (partial config fails fast at boot):
#
#   BINDU_GATEWAY_DID_SEED   — 32-byte Ed25519 seed, base64 encoded.
#                              Generate one with:
#                                  python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
#                              Treat as a secret. Leaking the seed = leaking the identity.
#   BINDU_GATEWAY_AUTHOR     — author identifier (typically email). Embedded in the DID.
#   BINDU_GATEWAY_NAME       — short gateway name. Embedded in the DID.
#
# The derived DID is `did:bindu:<author>:<name>:<agent_id>` where `agent_id`
# is sha256(publicKey)[:16] UUID-formatted — stable across restarts as long
# as the seed doesn't change. The DID is logged at boot; register it +
# the public key (also logged) with each peer's Hydra before calling them.
#
# BINDU_GATEWAY_DID_SEED=
# BINDU_GATEWAY_AUTHOR=ops@example.com
# BINDU_GATEWAY_NAME=gateway
